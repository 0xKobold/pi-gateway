{
  "name": "@0xkobold/pi-gateway",
  "version": "0.2.0",
  "description": "Hermes-style messaging gateway for pi-coding-agent",
  "keywords": ["pi-package", "gateway", "messaging", "hermes"],
  "type": "module",
  "main": "./dist/index.ts",
  "exports": {
    ".": { "import": "./dist/index.ts" },
    "./sessions": { "import": "./dist/sessions/store.ts" },
    "./security": { "import": "./dist/security/auth.ts" },
    "./adapters": { "import": "./dist/adapters/discord.ts" }
